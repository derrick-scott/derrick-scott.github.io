        gap: 12px;
      }

      @media (max-width: 720px) {
        .daPlannedGrid { grid-template-columns: 1fr; }
      }

      .daPlannedCard {
        border: 1px solid var(--border);
        background: var(--surface2);
        border-radius: 14px;
        padding: 16px;
      }

      .daPlannedIcon {
        font-size: 22px;
        margin-bottom: 8px;
      }

      .daPlannedTitle {
        margin: 0;
        font-size: 17px;
        font-weight: 850;
        color: var(--text2);
      }

      /* Lightbox */
      .lightbox {
        border: 1px solid var(--border3);
        background: var(--overlayBg);
        border-radius: 18px;
        padding: 0;
        width: min(980px, 92vw);
      }

      .lightbox::backdrop {
        background: var(--backdrop);
      }

      .lightboxTop {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 14px;
        border-bottom: 1px solid var(--border);
      }

      .lightboxTitle {
        font-weight: 850;
        color: var(--text2);
      }

      .lightboxClose {
        padding: 9px 12px;
        border-radius: 12px;
        border: 1px solid var(--border3);
        background: var(--surface);
        color: var(--text2);
        cursor: pointer;
      }

      .lightboxClose:hover {
        background: var(--surfaceHover);
      }

      .lightboxImg {
        display: block;
        width: 100%;
        height: auto;
        border-bottom-left-radius: 18px;
        border-bottom-right-radius: 18px;
      }

      /* Image hover zoom */
      .imgButton {
        display: block;
        width: 100%;
        padding: 0;
        border: 0;
        background: transparent;
        cursor: pointer;
        border-radius: 14px;
        overflow: hidden;
      }

      .imgButton .img {
        transition: transform .3s ease;
      }

      .imgButton:hover .img {
        transform: scale(1.05);
      }
    </style>
  </body>
</html>
