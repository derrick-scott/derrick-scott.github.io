---
import "../styles/global.css";
---

<!doctype html>
<html lang="en" data-theme="default">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Derrick Scott | Portfolio</title>
    <meta
      name="description"
      content="Data analytics, development, and technical work by Derrick Scott."
    />

    <!-- Small page-only tweaks for the hero layout + headshot crop -->
    <style>
      /* Make the left side a column so we can pin pills to the bottom */
      .heroLeft{
        display: flex;
        flex-direction: column;
        min-height: 100%;
      }

      /* Push the pill row to the bottom of the hero-left column */
      .heroLeft .heroMeta{
        margin-top: auto;
        padding-top: 14px;
      }

      /* Optional: slightly tighten vertical rhythm */
      .heroTitle{ margin-bottom: 10px; }

      /* Headshot: keep original sizing (not tall), but lightly crop away empty padding */
      .humanImgWrap{
        /* keep your global styles, just ensure overflow crops the transform */
        overflow: hidden;
      }

      .humanImg{
        width: 100%;
        height: auto;
        display: block;
      }

      /* Copy inside the human card: clean and not cheesy */
      .humanNotes{
        margin: 10px 0 0;
        line-height: 1.55;
        font-size: 14px;
      }

      /* Featured projects styling */
      .featuredGrid{
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
        margin-top: 14px;
      }

      @media (max-width: 900px){
        .featuredGrid{ grid-template-columns: 1fr; }
      }

      .featuredProjectWrap{
        position: relative;
        border: 1px solid var(--border3);
        background: var(--surface);
        border-radius: 18px;
        padding: 16px;
        transition: transform .18s ease, background .18s ease, border-color .18s ease;
      }

      .featuredProjectWrap:hover{
        transform: translateY(-2px);
        background: var(--surfaceHover);
        border-color: var(--border3);
      }

      .featuredProjectLink{
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        text-decoration: none;
      }

      .featuredBadge{
        position: relative;
        z-index: 0;
        display: inline-block;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 999px;
        background: var(--accentBg);
        color: var(--accentText);
        margin-bottom: 10px;
        pointer-events: none;
      }

      .featuredTitle{
        position: relative;
        z-index: 0;
        font-size: 20px;
        font-weight: 850;
        letter-spacing: .1px;
        margin: 0 0 8px;
        color: var(--text2);
        pointer-events: none;
      }

      .featuredDesc{
        position: relative;
        z-index: 0;
        margin: 0 0 14px;
        line-height: 1.6;
        color: var(--textSoft);
        pointer-events: none;
      }

      .featuredActions{
        position: relative;
        z-index: 2;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        pointer-events: none;
      }

      .featuredActions a{
        pointer-events: auto;
      }
    </style>
  </head>

  <body>
    <!-- Header -->
    <header class="topbar">
      <div class="container topbarInner">
        <a class="brand" href="/" aria-label="Home">
          <div class="brandText">
            <div class="brandKicker">Data Analyst & Developer</div>
            <div class="brandName">Derrick Scott</div>
          </div>
        </a>

        <nav class="topnav" aria-label="Primary navigation">
          <a class="navLink" href="/analytics">Data Analytics</a>
          <a class="navLink" href="/product">Product & Tech</a>
          <a class="navLink" href="/creative">Creative</a>
          <a class="navBtn" href="/#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main class="container" style="padding: 18px 0 58px;">
      <!-- Hero -->
      <section class="hero card">
        <div class="heroGrid">
          <div class="heroLeft">
            <h1 class="heroTitle">Aesthetic Designs, Purposefully Crafted</h1>
            <p class="muted heroIntro">Hi, I'm Derrick Scott!</p>
<p class="muted heroText">
  I'm currently persuing <strong>data analytics</strong>, combining a foundation in
  <strong>UX and technical writing</strong> with hands-on work in data wrangling, visualization, and
  documentation. My <strong>Computer Graphics Technology degree</strong> gave me a systems mindset and
  an eye for structure that carries directly into how I think about data. If you want the clearest picture
  of where I'm headed, <strong>start with Data Analytics.</strong>
</p>

            <div class="heroActions">
              <a class="button" href="/analytics">Data Analytics</a>
              <a class="button ghost" href="#work">Browse all work</a>
            </div>

            <!-- Pills pinned to the bottom of the left column -->
            <div class="heroMeta" aria-label="Focus areas">
              <span class="pill">Data Analytics</span>
              <span class="pill">UX</span>
              <span class="pill">Technical Writing</span>
              <span class="pill">Python</span>
              <span class="pill">SQL</span>
            </div>
          </div>

          <div class="heroRight">
            <div class="humanCard">
              <div class="humanTop">
                <div class="dot" aria-hidden="true"></div>
                <div>
                  <div class="humanTitle">About</div>
                  <div class="muted humanSub">Analyst in training. Designer by background.</div>
                </div>
              </div>

              <div class="humanImgWrap">
                <img class="humanImg" src="/assets/headshot.png" alt="Headshot" loading="lazy" />
              </div>

              <p class="muted humanNotes">
                North Carolina based. Computer Graphics Technology degree with a UX concentration from North Carolina A&T. Now building toward data analytics, where my documentation and systems thinking translate directly.
              </p>
            </div>
          </div>
        </div>

        <div class="heroGlow" aria-hidden="true"></div>
      </section>

      <!-- Featured Projects -->
      <section id="featured" style="margin-top: 18px;">
        <div class="card sectionCard">
          <div class="sectionHead">
            <h2 class="h2" style="margin:0;">Featured Projects</h2>
            <p class="muted" style="margin:6px 0 0; max-width: 78ch;">
              Recent work that demonstrates my approach to documentation and UX thinking.
            </p>
          </div>

          <div class="featuredGrid">
            <!-- Stock Analytics Pipeline -->
            <div class="featuredProjectWrap">
              <a href="/analytics#stock-pipeline" class="featuredProjectLink" aria-label="View Stock Analytics Pipeline project"></a>
              <span class="featuredBadge">IBM Certification Project</span>
              <h3 class="featuredTitle">End-to-End Stock Market Analytics Pipeline</h3>
              <p class="featuredDesc">
                A fully automated, config-driven pipeline covering five tickers and an S&P 500 benchmark:
                yfinance price extraction, web-scraped revenue data, five financial metrics, and nine
                interactive Plotly dashboards.
              </p>
              <div class="featuredActions">
                <a class="button" href="https://github.com/derrickscottux-collab/stock-analytics-pipeline" target="_blank" rel="noreferrer">View Repo</a>
                <a class="button ghost" href="/analytics#stock-pipeline">Project Details</a>
              </div>
            </div>

            <!-- Developer Ecosystem Analysis 2024 -->
            <div class="featuredProjectWrap">
              <a href="/analytics#developer-ecosystem-capstone" class="featuredProjectLink" aria-label="View Developer Ecosystem Analysis 2024 project"></a>
              <span class="featuredBadge">IBM Capstone Project</span>
              <h3 class="featuredTitle">Developer Ecosystem Analysis 2024</h3>
              <p class="featuredDesc">
                A consolidated analysis combining job posting APIs, web-scraped salary data, and the 2024
                Stack Overflow Developer Survey into a three-tab IBM Cognos dashboard with business
                recommendations.
              </p>
              <div class="featuredActions">
                <a class="button" href="https://github.com/derrickscottux-collab/ibm-data-analyst-capstone" target="_blank" rel="noreferrer">View Repo</a>
                <a class="button ghost" href="/analytics#developer-ecosystem-capstone">Project Details</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Work hub (4 sections only) -->
      <section id="work" style="margin-top: 18px;">
        <div class="card sectionCard">
          <div class="sectionHead">
            <h2 class="h2" style="margin:0;">Work</h2>
            <p class="muted" style="margin:6px 0 0; max-width: 78ch;">
              Three areas. If you only click one, start with Data Analytics.
            </p>
          </div>

          <div class="tileGrid" style="grid-template-columns: repeat(3, minmax(0, 1fr));">
            <a class="tile" href="/analytics">
              <div class="tileTop">
                <div class="tileTitle">Data Analytics</div>
                <div class="tileArrow" aria-hidden="true">→</div>
              </div>
              <div class="tileDesc">Data wrangling, visualization, and analytics projects built on a UX foundation.</div>
              <div class="chips">
                <span class="chip">Python</span>
                <span class="chip">SQL</span>
                <span class="chip">Viz</span>
              </div>
            </a>

            <a class="tile" href="/product">
              <div class="tileTop">
                <div class="tileTitle">Product & Technical Work</div>
                <div class="tileArrow" aria-hidden="true">→</div>
              </div>
              <div class="tileDesc">API documentation, UX projects, and technical writing.</div>
              <div class="chips">
                <span class="chip">OpenAPI</span>
                <span class="chip">UX</span>
                <span class="chip">Docs</span>
              </div>
            </a>

            <a class="tile" href="/creative">
              <div class="tileTop">
                <div class="tileTitle">Creative Work</div>
                <div class="tileArrow" aria-hidden="true">→</div>
              </div>
              <div class="tileDesc">Visual design, game development, and exploratory projects.</div>
              <div class="chips">
                <span class="chip">Visual</span>
                <span class="chip">Game Design</span>
                <span class="chip">Branding</span>
              </div>
            </a>
          </div>
        </div>
      </section>

      <!-- Contact -->
      <section id="contact" style="margin-top: 18px;">
        <div class="card sectionCard">
          <div class="sectionHead">
            <h2 class="h2" style="margin:0;">Contact</h2>
            <p class="muted" style="margin:6px 0 0; max-width: 78ch;">
              For roles, collaborations, or questions about anything here.
            </p>
          </div>

          <div class="contactRow">
            <a class="button" href="mailto:derrick.scott.dev@gmail.com">Email</a>
            <a class="button ghost" href="https://www.linkedin.com/in/derrick-scott-980109236/" target="_blank" rel="noreferrer">LinkedIn</a>
            <a class="button ghost" href="https://github.com/derrick-scott" target="_blank" rel="noreferrer">GitHub</a>
          </div>

        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container footerInner">
        <div class="footerLeft">
          <div class="footerBrand">Derrick Scott</div>
                    <p class="muted footerText">Data analytics, development, and technical work.</p>

          <p class="muted footerText" style="margin-top:10px;">
            © <span id="year"></span> Derrick Scott · North Carolina, USA
          </p>
        </div>

        <div class="footerCols">
          <div class="footerCol">
            <div class="footerHead">Work</div>
              <a class="footerLink" href="/analytics">Data Analytics</a>
            <a class="footerLink" href="/product">Product & Technical Work</a>
            <a class="footerLink" href="/creative">Creative Work</a>
          </div>

          <div class="footerCol">
            <div class="footerHead">Links</div>
            <a class="footerLink" href="#contact">Contact</a>
            <a class="footerLink" href="https://www.linkedin.com/in/derrick-scott-980109236/" target="_blank" rel="noreferrer">LinkedIn</a>
            <a class="footerLink" href="https://github.com/derrick-scott" target="_blank" rel="noreferrer">GitHub</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      document.getElementById("year").textContent = String(new Date().getFullYear());
    </script>
  </body>
</html>